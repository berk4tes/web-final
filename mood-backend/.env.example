PORT=5001
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/mood-entertainment
JWT_SECRET=your_jwt_secret_here_min_32_chars

# AI provider — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Movie/Series — TMDB — https://www.themoviedb.org/settings/api  (free)
TMDB_API_KEY=your_tmdb_api_key

# Music — Spotify — https://developer.spotify.com/dashboard  (free)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Music mood/tags — Last.fm — https://www.last.fm/api/account/create  (free)
LASTFM_API_KEY=your_lastfm_api_key
LASTFM_SHARED_SECRET=your_lastfm_shared_secret

# Books — Open Library — https://openlibrary.org  (no key needed, public API)
OPENLIBRARY_BASE_URL=https://openlibrary.org

NODE_ENV=development
FRONTEND_URL=http://localhost:5173
